DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://postgres:postgres@db:5432/aegis
CORS_ALLOWED_ORIGINS=http://localhost:5173
API_PORT=18080
CELERY_BROKER_URL=redis://redis:6379/0
NETWORK_SCAN_MAX_CONNECTIONS=120
NETWORK_SCAN_MAX_HOSTS=256
NETWORK_SCAN_MAX_CIDR_ADDRESSES=65536
NETWORK_SCAN_MIN_IPV4_PREFIX=16
NETWORK_SCAN_MIN_IPV6_PREFIX=48
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=security@aegis.local
CONTACT_INBOX_EMAIL=security@aegis.local
CONTACT_WEBHOOK_URL=
CONTACT_CONFIRMATION_SUBJECT=We received your security request
CONTACT_CONFIRMATION_BODY=Hi {name},\n\nThanks for reaching out to the Aegis security team. We have received your request and will respond within 1 business day.\n\nSummary:\n- Organization: {company}\n- Message: {message}\n\nRegards,\nAegis Security Team
